#!/bin/bash
echo "🧘 Starting Zen Net Installation..."

# 1. Setup Project Directory
mkdir -p ~/ZenNetProject && cd ~/ZenNetProject
mkdir -p src-tauri/src
mkdir -p src

# 2. Create the missing Config (tauri.conf.json)
cat <<EOF > src-tauri/tauri.conf.json
{
  "build": { "beforeBuildCommand": "", "beforeDevCommand": "", "devPath": "../src", "distDir": "../src" },
  "package": { "productName": "zen-net", "version": "0.1.0" },
  "tauri": {
    "allowlist": { "all": true },
    "bundle": { "active": true, "category": "DeveloperTool", "icon": [], "identifier": "com.zen.net", "targets": ["dmg"] },
    "security": { "csp": null },
    "windows": [{ "fullscreen": false, "height": 600, "resizable": true, "title": "Zen Net", "width": 800 }]
  }
}
EOF

# 3. Create Cargo.toml
cat <<EOF > src-tauri/Cargo.toml
[package]
name = "zen-net"
version = "0.1.0"
edition = "2021"
[build-dependencies]
tauri-build = "1.5"
[dependencies]
tauri = { version = "1.5", features = ["shell-open"] }
flate2 = "1.0"
EOF

# 4. Create Rust Logic
cat <<EOF > src-tauri/src/main.rs
use flate2::write::ZlibEncoder;
use flate2::Compression;
use std::io::Write;
use std::net::TcpStream;
fn compress_data(data: &[u8]) -> Result<Vec<u8>, String> {
    let mut encoder = ZlibEncoder::new(Vec::new(), Compression::default());
    encoder.write_all(data).map_err(|e| e.to_string())?;
    Ok(encoder.finish().map_err(|e| e.to_string())?)
}
#[tauri::command]
async fn zen_execute(code: String, port: String) -> String {
    let ports = ["8392", "8393", "8394", "8395", "8396", "8397"];
    let targets: Vec<String> = if port == "ALL" { ports.iter().map(|s| s.to_string()).collect() } else { vec![port] };
    for p in targets {
        if let Ok(mut stream) = TcpStream::connect(format!("127.0.0.1:{}", p)) {
            if code != "NULL" {
                let compressed = compress_data(code.as_bytes()).unwrap_or_default();
                let _ = stream.write_all(&compressed);
            }
            return format!("Zen Net: Success on port {}", p);
        }
    }
    "Connection Failed".into()
}
fn main() {
    tauri::Builder::default().invoke_handler(tauri::generate_handler![zen_execute]).run(tauri::generate_context!()).expect("error");
}
EOF

# 5. Create the GUI
cat <<EOF > src/index.html
<!DOCTYPE html>
<html><body style="background:#0b0b0d;color:#a370f7;font-family:sans-serif;text-align:center;padding:20px;">
    <h1>ZEN NET</h1>
    <select id="p"><option value="ALL">ALL PORTS</option><option value="8392">8392</option></select><br><br>
    <textarea id="c" style="width:90%;height:200px;background:#16161a;color:#50fa7b;" placeholder="OpiumwareScript print('Zen')"></textarea><br>
    <button onclick="run()" style="margin-top:10px;padding:10px 20px;">EXECUTE</button>
    <p id="s">Ready</p>
    <script>
        const { invoke } = window.__TAURI__.tauri;
        async function run() {
            const res = await invoke('zen_execute', { code: document.getElementById('c').value, port: document.getElementById('p').value });
            document.getElementById('s').innerText = res;
        }
    </script>
</body></html>
EOF

echo "🛠 Final Build..."
cargo tauri build
