#!/bin/bash
echo "🧘 Starting Zen Net (Fast-Track)..."

# 1. Clean and Setup
rm -rf ~/ZenNetProject
mkdir -p ~/ZenNetProject/src-tauri/src
mkdir -p ~/ZenNetProject/src
cd ~/ZenNetProject

# 2. Simplified Config
cat <<EOF > src-tauri/tauri.conf.json
{
  "build": { "devPath": "../src", "distDir": "../src" },
  "package": { "productName": "zen-net", "version": "0.1.0" },
  "tauri": {
    "allowlist": { "all": true },
    "bundle": { "active": false, "identifier": "com.zen.net" },
    "windows": [{ "title": "Zen Net", "width": 800, "height": 600 }]
  }
}
EOF

# 3. Cargo.toml
cat <<EOF > src-tauri/Cargo.toml
[package]
name = "zen-net"
version = "0.1.0"
edition = "2021"
[dependencies]
tauri = { version = "1.5", features = ["shell-open"] }
flate2 = "1.0"
[build-dependencies]
tauri-build = "1.5"
EOF

# 4. Create Build Script
echo 'fn main() { tauri_build::build() }' > src-tauri/build.rs

# 5. Rust Logic
cat <<EOF > src-tauri/src/main.rs
use flate2::write::ZlibEncoder;
use flate2::Compression;
use std::io::Write;
use std::net::TcpStream;
fn compress(d: &[u8]) -> Vec<u8> {
    let mut e = ZlibEncoder::new(Vec::new(), Compression::default());
    e.write_all(d).unwrap();
    e.finish().unwrap()
}
#[tauri::command]
async fn zen_execute(code: String, port: String) -> String {
    let p = if port == "ALL" { "8392" } else { &port };
    if let Ok(mut s) = TcpStream::connect(format!("127.0.0.1:{}", p)) {
        let _ = s.write_all(&compress(code.as_bytes()));
        return format!("Sent to {}", p);
    }
    "Failed".into()
}
fn main() {
    tauri::Builder::default()
        .invoke_handler(tauri::generate_handler![zen_execute])
        .run(tauri::generate_context!())
        .expect("err");
}
EOF

# 6. GUI
cat <<EOF > src/index.html
<!DOCTYPE html>
<html><body style="background:#000;color:#fff;text-align:center;padding:50px;">
    <h1>ZEN NET</h1>
    <textarea id="c" style="width:80%;height:100px;background:#222;color:#0f0;"></textarea><br>
    <button onclick="run()">EXECUTE</button>
    <p id="s"></p>
    <script>
        const { invoke } = window.__TAURI__.tauri;
        async function run() {
            const res = await invoke('zen_execute', { code: document.getElementById('c').value, port: '8392' });
            document.getElementById('s').innerText = res;
        }
    </script>
</body></html>
EOF

echo "🚀 Launching Zen Net..."
cargo tauri dev
